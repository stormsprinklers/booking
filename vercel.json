{
  "crons": [
    {
      "path": "/api/leads/send-abandoned",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    { "source": "/:path*", "destination": "/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
